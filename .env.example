# Neon / Postgres connection string.
# Copy your own value from Neon Console. Do not commit real credentials.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# mock: 本地不调用模型，方便联调；ark: 调用火山方舟/豆包真实接口
AI_PROVIDER="mock"

# 真实调用时填写，不要提交到公开仓库
ARK_API_KEY=""
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_IMAGE_MODEL="doubao-seedream-5-0-260128"
ARK_VISION_MODEL="doubao-seed-2-0-lite-260428"

# 真实图生图需要公网可访问图片。上线后填你的域名或对象存储域名。
PUBLIC_APP_URL="http://127.0.0.1:3000"

# 图片存储。local 用于本地开发；没有银行卡时线上推荐 cloudinary；有付款方式后也可以用 r2。
STORAGE_PROVIDER="local"

# Cloudinary。只有 STORAGE_PROVIDER="cloudinary" 时才需要填写。
# Cloudinary 免费档不需要信用卡，适合先上线轻量 MVP。
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Cloudflare R2。只有 STORAGE_PROVIDER="r2" 时才需要填写。
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="flora-story"
# 这里填公开访问域名，例如 https://pub-xxxx.r2.dev 或你的自定义域名。
# 不要填 https://<account-id>.r2.cloudflarestorage.com 这个私有 S3 API endpoint。
R2_PUBLIC_BASE_URL=""

# 邮箱验证码登录。mock 会在本地把验证码打印到服务端日志；上线必须使用 resend。
EMAIL_PROVIDER="mock"
RESEND_API_KEY=""
MAIL_FROM="Flora Story <onboarding@resend.dev>"
AUTH_COOKIE_NAME="flora_session"
SESSION_DAYS="30"
